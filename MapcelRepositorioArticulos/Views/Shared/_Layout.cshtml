<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - MapcelRepositorioArticulos</title>
    
    <link rel="stylesheet" href="./Dhtmlx/skins/material/dhtmlx.css" />
    <link rel="stylesheet" href="css/global.css"/>
    <link rel="stylesheet" href="css/site.css"/>
    <script type="importmap"></script>
    <script src="./Dhtmlx/codebase/dhtmlx.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.8/dist/purify.min.js"></script>
    <!-- Editor.js Core and Tools -->
    <script src="https://cdn.jsdelivr.net/npm/@@editorjs/editorjs@@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@editorjs/header@@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@editorjs/list@@2"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@editorjs/table@@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@editorjs/code@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@editorjs/delimiter@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@editorjs/simple-image"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@editorjs/image@latest"></script>
    <!-- Editor.js JSON-to-HTML parser -->
    <script src="https://cdn.jsdelivr.net/npm/editorjs-html@@4.0.0/.build/edjsHTML.js"></script>
</head>
<body>
@RenderBody()
@if (User.Identity?.IsAuthenticated ?? false)
{
    <script src="~/js/adminComponents.js" asp-append-version="true"></script>
}
    
<!-- Data Models and Services -->
<script src="./js/utils.js"></script>
<script src="./js/dataModels.js"></script>
<script src="./js/articleService.js"></script>
<script src="./js/userService.js"></script>
<script src="./js/companyService.js"></script>
<script src="./js/companyRouting.js"></script>
<script src="./js/gridFilterService.js"></script>
<script src="./js/fileService.js"></script>
<script src="./js/imageService.js"></script>
  
<!-- UI Helpers -->
<script src="./js/tagBadge.js"></script>
<script src="./js/articleDetailUI.js"></script>
<script src="./js/companyFormUI.js"></script>
<script src="./js/articlesGridHelper.js"></script>
<script src="./js/tagManagerUI.js"></script>
<script src="./js/tagPickerUI.js"></script>
<script src="./js/articleFormUI.js"></script>
<script src="./js/bulkTagEditorUI.js"></script>
<script src="./js/filesGridHelper.js"></script>
<script src="./js/filesCardViewUI.js"></script>
<script src="./js/fileUploadUI.js"></script>
<script src="./js/fileMetadataEditorUI.js"></script>
<script src="./js/filesTabManager.js"></script>
<script src="./js/imagesGridHelper.js"></script>
<script src="./js/imagesGalleryViewUI.js"></script>
<script src="./js/imageMetadataEditorUI.js"></script>
<script src="./js/imagePreviewModal.js"></script>
<script src="./js/imageUploadUI.js"></script>
<script src="./js/imagesTabManager.js"></script>
<script src="./js/newArticlePageUI.js"></script>
<!-- Main Application -->
<script src="./js/app.js"></script>
<!-- Lucide Icons -->
<script src="https://unpkg.com/lucide@latest"></script>
<script>
    lucide.createIcons();
  </script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>